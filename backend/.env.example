# ─── Copy this file to .env and fill in your values ───────────────────────────

# Database (default uses SQLite - no setup needed for development)
DATABASE_URL=sqlite:///./legal_assistant.db

# For PostgreSQL (optional):
# DATABASE_URL=postgresql://user:password@localhost:5432/legal_assistant

# JWT Secret Key - CHANGE THIS in production!
SECRET_KEY=change-this-to-a-very-long-random-secret-key-in-production

# Google Gemini API Key (get from https://aistudio.google.com)
# If left empty, the app runs with mock AI responses
GEMINI_API_KEY=your_gemini_api_key_here

# Redis URL (optional) - enables query history caching and session case limits.
# If not set or Redis is unreachable, the app falls back to database silently.
# REDIS_URL=redis://localhost:6379/0
